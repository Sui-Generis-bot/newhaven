# ─── Company Directory – Backend Environment ─────────────────────────────────
# Copy this file to .env and fill in your values before running.

NODE_ENV=development

# Server
PORT=3001

# Session secret – generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MINIMUM_64_CHARS

# Frontend origin (for CORS)
ALLOWED_ORIGIN=http://localhost:5173

# SQLite DB path (relative to backend/)
# DB_PATH=./data/directory.db
